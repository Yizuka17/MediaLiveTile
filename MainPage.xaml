<Page
    x:Class="MediaLiveTile.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MediaLiveTile"
    xmlns:model="using:MediaLiveTile.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Media Live Tile"
                       FontSize="42"/>
            <TextBlock Text="系统媒体动态磁贴预览"
                       Margin="0,4,0,24"
                       Opacity="0.7"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="760"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- 左栏：预览 -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Margin="0,0,24,0">
                <StackPanel>
                    <TextBlock Text="预览"
                               FontSize="28"
                               FontWeight="SemiBold"/>

                    <!-- 小磁贴 -->
                    <StackPanel Orientation="Horizontal" Margin="0,24,0,8">
                        <TextBlock Text="小磁贴"
                                   VerticalAlignment="Center"/>
                        <Button Content="固定磁贴"
                                Click="PinSmallTileButton_Click"
                                Margin="12,0,0,0"
                                MinWidth="96"/>
                    </StackPanel>

                    <Border x:Name="SmallTilePreviewRoot"
                            Width="71"
                            Height="71"
                            Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                        <Grid>
                            <Image x:Name="SmallPreviewImage"
                                   Stretch="UniformToFill"/>
                            <TextBlock x:Name="SmallPreviewPlaceholderText"
                                       Text="♪"
                                       FontSize="22"
                                       Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 中磁贴 -->
                    <StackPanel Orientation="Horizontal" Margin="0,24,0,8">
                        <TextBlock Text="中磁贴（封面 / 信息）"
                                   VerticalAlignment="Center"/>
                        <Button Content="固定磁贴"
                                Click="PinMediumTileButton_Click"
                                Margin="12,0,0,0"
                                MinWidth="96"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="MediumCoverPreviewRoot"
                                Width="150"
                                Height="150"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                            <Grid>
                                <Image x:Name="MediumCoverPreviewImage"
                                       Stretch="UniformToFill"/>
                                <TextBlock x:Name="MediumCoverPreviewPlaceholderText"
                                           Text="♪"
                                           FontSize="34"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border x:Name="MediumInfoPreviewRoot"
                                Width="150"
                                Height="150"
                                Margin="12,0,0,0"
                                Padding="12"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="MediumInfoTitleText"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Top"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="MediumInfoArtistText"
                                           Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="MediumInfoSourceText"
                                           Grid.Row="2"
                                           Margin="0,8,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 宽磁贴 -->
                    <StackPanel Orientation="Horizontal" Margin="0,24,0,8">
                        <TextBlock Text="宽磁贴"
                                   VerticalAlignment="Center"/>
                        <Button Content="固定磁贴"
                                Click="PinWideTileButton_Click"
                                Margin="12,0,0,0"
                                MinWidth="96"/>
                    </StackPanel>

                    <Border x:Name="WideTilePreviewRoot"
                            Width="310"
                            Height="150"
                            Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="150"
                                  Height="150"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center">
                                <Image x:Name="WidePreviewImage"
                                       Stretch="UniformToFill"/>
                                <TextBlock x:Name="WidePreviewPlaceholderText"
                                           Text="♪"
                                           FontSize="34"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Grid.Column="1" Margin="12,12,12,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="WideTitleText"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Top"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="WideArtistText"
                                           Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="WideSourceText"
                                           Grid.Row="2"
                                           Margin="0,8,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 大磁贴 -->
                    <StackPanel Orientation="Horizontal" Margin="0,24,0,8">
                        <TextBlock Text="大磁贴（封面 / 信息）"
                                   VerticalAlignment="Center"/>
                        <Button Content="固定磁贴"
                                Click="PinLargeTileButton_Click"
                                Margin="12,0,0,0"
                                MinWidth="96"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Border x:Name="LargeCoverPreviewRoot"
                                Width="310"
                                Height="310"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                            <Grid>
                                <Image x:Name="LargeCoverPreviewImage"
                                       Stretch="UniformToFill"/>
                                <TextBlock x:Name="LargeCoverPreviewPlaceholderText"
                                           Text="♪"
                                           FontSize="40"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border x:Name="LargeInfoPreviewRoot"
                                Width="310"
                                Height="310"
                                Margin="12,0,0,0"
                                Padding="18"
                                Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="LargeInfoTitleText"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Top"
                                           MaxLines="3"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="LargeInfoArtistText"
                                           Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="2"
                                           TextWrapping="WrapWholeWords"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock x:Name="LargeInfoSourceText"
                                           Grid.Row="2"
                                           Margin="0,12,0,0"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumHighBrush}"
                                           TextAlignment="Left"
                                           HorizontalAlignment="Stretch"
                                           MaxLines="1"
                                           TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- 中栏：控制 / 监测 -->
            <Grid Grid.Column="1" Margin="0,0,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="控制 / 监测"
                           FontSize="28"
                           FontWeight="SemiBold"/>

                <StackPanel Grid.Row="1" Margin="0,20,0,0">
                    <TextBlock Text="磁贴显示目标"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="小磁贴"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="SmallTargetComboBox"
                                  Grid.Column="1"
                                  Width="120"
                                  ItemsSource="{x:Bind TargetOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="SmallTargetComboBox_SelectionChanged"/>

                        <TextBlock Grid.Row="1"
                                   Text="中磁贴"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="MediumTargetComboBox"
                                  Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Width="120"
                                  ItemsSource="{x:Bind TargetOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="MediumTargetComboBox_SelectionChanged"/>

                        <TextBlock Grid.Row="2"
                                   Text="宽磁贴"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="WideTargetComboBox"
                                  Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Width="120"
                                  ItemsSource="{x:Bind TargetOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="WideTargetComboBox_SelectionChanged"/>

                        <TextBlock Grid.Row="3"
                                   Text="大磁贴"
                                   Margin="0,8,0,0"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="LargeTargetComboBox"
                                  Grid.Row="3"
                                  Grid.Column="1"
                                  Margin="0,8,0,0"
                                  Width="120"
                                  ItemsSource="{x:Bind TargetOptions, Mode=OneWay}"
                                  DisplayMemberPath="DisplayText"
                                  SelectionChanged="LargeTargetComboBox_SelectionChanged"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <ToggleSwitch x:Name="AutoRefreshToggle"
                                      Header="自动刷新监测（30 秒）"
                                      Toggled="AutoRefreshToggle_Toggled"/>

                        <Button x:Name="RefreshButton"
                                Content="立即刷新磁贴"
                                Click="RefreshButton_Click"
                                Margin="20,28,0,0"
                                Height="40"/>
                    </StackPanel>

                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,16,0,0"
                               Text="等待刷新"/>
                    <TextBlock x:Name="PrimaryMediaTextBlock"
                               Margin="0,8,0,0"
                               Text="主媒体：无"/>
                    <TextBlock x:Name="SecondaryMediaTextBlock"
                               Margin="0,4,0,0"
                               Text="次媒体：无"/>
                    <TextBlock x:Name="LastRefreshTextBlock"
                               Margin="0,4,0,0"
                               Opacity="0.7"
                               Text="上次刷新：--"/>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="媒体会话（前 4 项）"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,28,0,12"/>

                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListView ItemsSource="{x:Bind VisibleSessions, Mode=OneWay}"
                              SelectionMode="None"
                              IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="model:MediaSessionInfo">
                                <Border Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                                        Padding="8"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="52"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="52"
                                              Height="52"
                                              Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                            <Image Source="{x:Bind DisplayImage}"
                                                   Stretch="UniformToFill"/>

                                            <TextBlock Text="{x:Bind ThumbnailPlaceholderText}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource SystemControlForegroundBaseHighBrush}"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                            <TextBlock Text="{x:Bind SourceDisplayName}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind Role}"
                                                       Opacity="0.8"/>
                                            <TextBlock Text="{x:Bind Title}"
                                                       MaxLines="1"
                                                       TextTrimming="CharacterEllipsis"
                                                       Opacity="0.9"/>
                                            <TextBlock Text="{x:Bind PlaybackStatus}"
                                                       Opacity="0.7"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button x:Name="MoreMediaButton"
                            Grid.Row="1"
                            Content="查看更多媒体"
                            Click="MoreMediaButton_Click"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Visibility="Collapsed"/>
                </Grid>
            </Grid>

            <!-- 右栏：日志 / 关于 -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="更多"
                           FontSize="28"
                           FontWeight="SemiBold"/>

                <Button x:Name="OpenLogButton"
                        Content="打开日志"
                        Click="OpenLogButton_Click"
                        Height="48"
                        Margin="0,24,0,12"/>

                <Button x:Name="AboutAppButton"
                        Content="关于此应用"
                        Click="AboutAppButton_Click"
                        Height="48"/>

                <TextBlock x:Name="ActionStatusTextBlock"
                           Margin="0,16,0,0"
                           Opacity="0.8"
                           TextWrapping="WrapWholeWords"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>